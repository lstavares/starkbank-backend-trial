STARKBANK_ENVIRONMENT=sandbox
STARKBANK_PROJECT_ID=
# Prefer using a local key path. Files ending in .pem and .key are ignored by git.
STARKBANK_PRIVATE_KEY_PATH=
# Optional inline PEM alternative. Use escaped \n if your shell requires a single line.
STARKBANK_PRIVATE_KEY=

DATABASE_URL=jdbc:postgresql://localhost:5432/starkbank_trial
DATABASE_USERNAME=starkbank
DATABASE_PASSWORD=starkbank

INVOICE_SCHEDULER_ENABLED=true
INVOICE_INTERVAL_HOURS=3
INVOICE_MAX_BATCHES=8
SERVER_PORT=8080
